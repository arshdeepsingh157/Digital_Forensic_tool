# ==============================
# DATABASE CONFIGURATION
# ==============================

# PostgreSQL - Structured Data
POSTGRES_USER=forensic_user
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=forensic_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# MongoDB - Unstructured Data & Logs
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=forensic_logs

# Redis - Caching & Queue
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==============================
# API CONFIGURATION
# ==============================

API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=v1
API_TITLE=AI-Powered Digital Forensics API
DEBUG_MODE=True

# Secret Key (Generate with: openssl rand -hex 32)
SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==============================
# FILE STORAGE CONFIGURATION
# ==============================

STORAGE_PATH=./storage
UPLOAD_FOLDER=./storage/uploads
PROCESSED_FOLDER=./storage/processed
TEMP_FOLDER=./storage/temp

# File Upload Limits
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,docx,doc

# ==============================
# FORENSIC ANALYSIS SETTINGS
# ==============================

# ELA Settings
ELA_QUALITY=95
ELA_SCALE=10

# Scoring Thresholds
AUTHENTIC_THRESHOLD=90
SUSPICIOUS_THRESHOLD=60

# Scoring Weights (must sum to 1.0)
WEIGHT_METADATA=0.30
WEIGHT_HASH=0.30
WEIGHT_ELA=0.20
WEIGHT_NOISE=0.20

# ==============================
# AIRFLOW CONFIGURATION
# ==============================

AIRFLOW_HOME=./airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://forensic_user:change_this_secure_password@localhost:5432/forensic_db
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__WEBSERVER__SECRET_KEY=your_airflow_secret_key

# ==============================
# DASHBOARD CONFIGURATION
# ==============================

DASHBOARD_PORT=8501
DASHBOARD_THEME=dark

# ==============================
# LOGGING CONFIGURATION
# ==============================

LOG_LEVEL=INFO
LOG_FILE=./logs/forensic_system.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# ==============================
# AWS S3 CONFIGURATION (Optional)
# ==============================

USE_S3=False
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=forensic-files

# ==============================
# EMAIL NOTIFICATIONS (Optional)
# ==============================

ENABLE_EMAIL=False
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=forensics@example.com
EMAIL_PASSWORD=your_email_password

# ==============================
# PERFORMANCE SETTINGS
# ==============================

WORKER_COUNT=4
MAX_CONCURRENT_UPLOADS=10
CACHE_TTL=3600  # seconds

# ==============================
# FEATURE FLAGS
# ==============================

ENABLE_AUTH=False
ENABLE_RATE_LIMITING=False
ENABLE_PYSPARK=False
ENABLE_PDF_REPORTS=True
ENABLE_NOTIFICATIONS=False
